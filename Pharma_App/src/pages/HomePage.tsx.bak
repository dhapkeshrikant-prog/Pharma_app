export const HomePage = ({ activeSlide, onAbout, onContact, onDetail, onExplore, onSlide, t }: HomePageProps) => {
  const categoryTiles = useMemo(() => {
    const map = new Map<string, { label: string; slug: string; count: number }>();
    products.forEach((product) => {
      const slug = product.categorySlug ?? product.category.toLowerCase().replace(/\s+/g, '-');
      const item = map.get(slug);
      map.set(slug, { label: product.category, slug, count: (item?.count ?? 0) + 1 });
    });
    return [...map.values()].slice(0, 7);
  }, []);

  const featured = useMemo(() => {
    const preferred = ['upstrin-forte', 'dazer-cv', 'snofreez', 'boneaya', 'azaya-lb'];
    return preferred.map((slug) => products.find((product) => product.slug === slug)).filter(Boolean) as Product[];
  }, []);

  return (
    <main className="home-page home-ref w-full overflow-hidden bg-white dark:bg-slate-950">
      <OpeningScene />
      <section className="home-ref-hero" id="home">
        <button className="home-ref-arrow left" onClick={() => onSlide(Math.max(activeSlide - 1, 0))} type="button" aria-label="Previous slide">
          <Icon name="arrow" className="rotate-180" />
        </button>
        <div className="home-ref-hero-inner">
          <motion.div initial={{ opacity: 0, x: -24 }} animate={{ opacity: 1, x: 0 }} transition={{ duration: 0.55 }}>
            <span className="home-ref-eyebrow">Quality-focused pharma company</span>
            <h1>Trusted Medicines For <span>A Healthier Life.</span></h1>
            <p>SUKHAYA Pharmaceutical delivers high-quality, safe, and affordable healthcare products built on quality assurance, doctor trust, and patient-first care.</p>
            <div className="home-ref-actions">
              <button className="home-ref-primary" onClick={onExplore} type="button">
                Explore Products <Icon name="arrow" className="h-4 w-4" />
              </button>
              <button className="home-ref-secondary" onClick={onContact} type="button">Contact Us</button>
            </div>
          </motion.div>
          <motion.div className="home-ref-showcase" initial={{ opacity: 0, scale: 0.94 }} animate={{ opacity: 1, scale: 1 }} transition={{ delay: 0.1, duration: 0.6 }}>
            <button className="home-ref-card-arrow left" onClick={() => onSlide(Math.max(activeSlide - 1, 0))} type="button" aria-label="Previous product">
              <Icon name="arrow" className="rotate-180" />
            </button>
            <div className="home-ref-photo">
              <img src="/product-images/NEURAYA Tablet Details Uses.jpeg" alt="Medicine blister packs" />
            </div>
            <div className="home-ref-float-card card-a">
              <strong>NEURAYA</strong>
              <span>MCB 1500 mcg, ALA 100 mg, Vit. D3</span>
            </div>
            <div className="home-ref-float-card card-b">
              <strong>PANAYA-40 DSR</strong>
              <span>Pantoprazole 40 mg, Domperidone SR</span>
            </div>
            <div className="home-ref-float-card card-c">
              <strong>SNOFREEZ</strong>
              <span>Tablets - Medicine showcase</span>
            </div>
            <button className="home-ref-card-arrow right" onClick={() => onSlide(activeSlide + 1)} type="button" aria-label="Next product">
              <Icon name="arrow" />
            </button>
            <div className="home-ref-dots card-dots"><span /><span /><span /><span /><span /></div>
          </motion.div>
        </div>
      </section>

      <section className="home-ref-section">
        <SectionTitle title="Our Categories" />
        <div className="home-ref-categories">
          {categoryTiles.map((category, index) => (
            <button key={category.slug} className="home-ref-category" onClick={onExplore} type="button">
              <span>{['Tb', 'Cp', 'Sy', 'Rx', 'Nu', 'Ca', 'Re'][index] ?? 'Rx'}</span>
              <strong>{category.label}</strong>
            </button>
          ))}
          <button className="home-ref-category" onClick={onExplore} type="button">
            <span>::</span>
            <strong>View All</strong>
          </button>
        </div>
      </section>

      <section className="home-ref-section">
        <div className="home-ref-title-row">
          <h2>Featured Products</h2>
          <button onClick={onExplore} type="button">View All Products</button>
        </div>
        <div className="home-ref-products">
          {featured.map((product, index) => (
            <FadeIn delay={index * 0.04} key={product.slug}>
              <article className="home-ref-product">
                <div className="home-ref-product-image">
                  <img src={product.image} alt={product.imageAlt ?? product.name} loading="lazy" />
                </div>
                <h3>{product.name}</h3>
                <p>{product.category}</p>
                <small>{product.composition || product.description}</small>
                <button onClick={() => onDetail(product)} type="button">View Details</button>
              </article>
            </FadeIn>
          ))}
        </div>
      </section>

      <StatsBand />
      <WhyChoose onAbout={onAbout} />
      <CtaBanner onContact={onContact} t={t} />
    </main>
  );
};

